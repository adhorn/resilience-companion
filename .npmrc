# Disable npm package lifecycle scripts by default.
#
# Supply-chain malware (e.g. the September 2025 / May 2026 Shai-Hulud worms)
# executes via preinstall / install / postinstall scripts. With this flag set,
# `npm install` and `npm ci` skip all those scripts — random transitive deps
# can't run arbitrary code on the developer's or CI's machine just by being
# installed.
#
# Two packages in this tree DO need install scripts to function:
#   - better-sqlite3 (compiles or downloads the native sqlite binding)
#   - esbuild       (downloads the platform-specific binary used by Vite)
# Those are explicitly rebuilt by `npm run setup`. When adding a new dep that
# requires install scripts to work, audit it carefully, then add it to the
# rebuild list in package.json's `setup` script.
ignore-scripts=true
