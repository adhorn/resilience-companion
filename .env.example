# Database path (relative to monorepo root). Auto-created on first boot.
DB_PATH=./data/resilience-companion.db

# Encryption key for repo tokens at rest (optional).
# Auto-generated on first boot if not set — stored in data/.encryption-key.
# Only set this if you want to manage it yourself.
# JWT_SECRET=

# LLM provider (optional — auto-detected from API key if not set)
# bedrock:  Amazon Bedrock (uses AWS credential chain, no LLM_API_KEY needed)
# Leave unset to auto-detect from LLM_API_KEY prefix
# LLM_PROVIDER=bedrock

# LLM provider API key
# Anthropic:         sk-ant-api03-...
# OpenAI-compatible: sk-...
# Bedrock:           not needed (uses AWS credentials)
# Leave empty to run without AI (structured review tool only)
LLM_API_KEY=

# LLM model (optional — supports shortnames)
# Anthropic: sonnet, opus, haiku, sonnet-4.6, opus-4.6, haiku-4.5
# Bedrock:   sonnet, opus, haiku (auto-mapped to Bedrock model IDs)
#            or full ID: us.anthropic.claude-sonnet-4-20250514-v1:0
# OpenAI:    gpt-4o (default), or any model name
LLM_MODEL=

# Base URL for OpenAI-compatible endpoints (optional — only needed for Azure, Ollama, etc.)
LLM_BASE_URL=

# AWS region for Bedrock (optional — defaults to us-east-1)
# AWS_REGION=us-east-1

# Server port (used by both npm run dev and inside the Docker container)
PORT=3000

# CORS origins (comma-separated). Defaults to localhost:5173,localhost:3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Host port for Docker (defaults to 3080 to avoid conflicts with npm run dev on 3000)
# DOCKER_PORT=3080
